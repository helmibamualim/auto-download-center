{
  "crons": [
    {
      "path": "/api/sync-batch",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/validate",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cleanup",
      "schedule": "0 4 1 * *"
    }
  ],
  "env": {
    "NODE_VERSION": "22.12.0"
  },
  "buildCommand": "npm run build"
}

  <!-- JavaScript for Modal -->
  <script>
    // Show QRIS Modal
    const showQrisBtn = document.getElementById('show-qris-btn');
    const qrisModal = document.getElementById('qris-modal');
    const closeQrisBtn = document.getElementById('close-qris-btn');

    showQrisBtn?.addEventListener('click', () => {
      qrisModal?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    });

    closeQrisBtn?.addEventListener('click', () => {
      qrisModal?.classList.add('hidden');
      document.body.style.overflow = 'auto';
    });

    // Close modal when clicking backdrop
    qrisModal?.addEventListener('click', (e) => {
      if (e.target === qrisModal) {
        qrisModal.classList.add('hidden');
        document.body.style.overflow = 'auto';
      }
    });

    // Close modal with Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !qrisModal?.classList.contains('hidden')) {
        qrisModal?.classList.add('hidden');
        document.body.style.overflow = 'auto';
      }
    });
  </script>


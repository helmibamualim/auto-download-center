---
import Layout from '../layouts/Layout.astro';

// SEO Configuration
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://auto-download-center.vercel.app';
const pageTitle = "Support the Platform / Dukung Platform - Auto Download Center";
const pageDescription = "Optional support for open source platform development. Your contribution helps us continue providing free, safe software downloads.";

// Support Links - Easy to update
const KOFI_URL = "https://ko-fi.com/autodownloadcenter"; // Replace with your Ko-fi username
const PATREON_URL = "https://www.patreon.com/autodownloadcenter"; // Replace with your Patreon username
---

<Layout 
  title={pageTitle}
  description={pageDescription}
  canonical={`${siteUrl}/donate`}
>
  <!-- Hero Section - Soft & Elegant -->
  <section class="relative bg-gradient-to-br from-purple-50/50 via-white to-blue-50/50 dark:from-gray-900 dark:via-gray-900 dark:to-gray-900 py-20 md:py-28 overflow-hidden">
    <!-- Subtle Background -->
    <div class="absolute inset-0 bg-grid-pattern opacity-[0.02]"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-purple-200 dark:bg-purple-900 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-3xl opacity-20 dark:opacity-10 animate-blob"></div>
    <div class="absolute top-0 right-1/4 w-96 h-96 bg-blue-200 dark:bg-blue-900 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-3xl opacity-20 dark:opacity-10 animate-blob animation-delay-2000"></div>
    
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- Subtle Badge -->
      <div class="inline-flex items-center px-5 py-2 rounded-full bg-white/60 dark:bg-gray-800/60 backdrop-blur-md border border-purple-200/50 dark:border-purple-800/50 text-purple-700 dark:text-purple-300 text-sm font-medium mb-8 shadow-sm">
        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"></path>
        </svg>
        Optional Support
      </div>

      <!-- Main Heading - Soft Approach -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-gray-100 mb-6 leading-tight">
        💜 Dukung Pengembangan Platform
      </h1>
      
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-700 dark:text-gray-300 mb-10 leading-tight">
        💜 Support the Platform
      </h2>
      
      <!-- Subtitle - Emphasize Optional -->
      <div class="max-w-2xl mx-auto space-y-6 mb-8">
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 leading-relaxed">
          Platform ini akan <span class="font-semibold text-gray-900 dark:text-gray-100">selalu gratis</span> untuk semua orang. 
          Jika Anda merasa terbantu, dukungan sukarela Anda akan sangat berarti untuk pengembangan berkelanjutan.
        </p>
        
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 leading-relaxed">
          This platform will <span class="font-semibold text-gray-900 dark:text-gray-100">always remain free</span> for everyone. 
          If you find it helpful, your voluntary support would mean a lot for continued development.
        </p>
      </div>

      <!-- No Obligation Message -->
      <div class="inline-flex items-center px-6 py-3 rounded-2xl bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-300 text-sm font-medium shadow-sm">
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
        </svg>
        <span class="mr-2">Tidak ada kewajiban.</span>
        <span>No obligation.</span>
      </div>
    </div>
  </section>
  <!-- Why Support Us Section - Glassmorphism Style -->
  <section class="py-20 bg-gradient-to-b from-white to-gray-50 dark:from-gray-900 dark:to-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3">
          Mengapa Mendukung Kami?
        </h2>
        <h3 class="text-2xl md:text-3xl font-bold text-gray-600 dark:text-gray-400 mb-4">
          Why Support Us?
        </h3>
        <p class="text-lg text-gray-500 dark:text-gray-500 max-w-2xl mx-auto">
          Dukungan Anda membantu kami terus berkembang / Your support helps us grow
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Card 1 - Glassmorphism -->
        <div class="group relative bg-white/70 dark:bg-gray-800/70 backdrop-blur-xl rounded-3xl p-6 border border-gray-200/50 dark:border-gray-700/50 hover:shadow-xl hover:shadow-purple-500/10 dark:hover:shadow-purple-500/20 transition-all duration-500 hover:-translate-y-1">
          <div class="w-14 h-14 bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-purple-500/30">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-2">
            Pengembangan Berkelanjutan
          </h3>
          <p class="text-sm text-gray-500 dark:text-gray-500 mb-3">
            Continuous Development
          </p>
          <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
            Fitur baru, perbaikan, dan peningkatan performa.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="group relative bg-white/70 dark:bg-gray-800/70 backdrop-blur-xl rounded-3xl p-6 border border-gray-200/50 dark:border-gray-700/50 hover:shadow-xl hover:shadow-pink-500/10 dark:hover:shadow-pink-500/20 transition-all duration-500 hover:-translate-y-1">
          <div class="w-14 h-14 bg-gradient-to-br from-pink-500 to-pink-600 rounded-2xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-pink-500/30">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-2">
            Bebas Iklan Berbahaya
          </h3>
          <p class="text-sm text-gray-500 dark:text-gray-500 mb-3">
            Ad-Free Experience
          </p>
          <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
            Platform tetap bersih tanpa iklan mengganggu.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="group relative bg-white/70 dark:bg-gray-800/70 backdrop-blur-xl rounded-3xl p-6 border border-gray-200/50 dark:border-gray-700/50 hover:shadow-xl hover:shadow-blue-500/10 dark:hover:shadow-blue-500/20 transition-all duration-500 hover:-translate-y-1">
          <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-blue-500/30">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-2">
            Untuk Komunitas
          </h3>
          <p class="text-sm text-gray-500 dark:text-gray-500 mb-3">
            Built for Community
          </p>
          <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
            Dibuat oleh komunitas, untuk komunitas.
          </p>
        </div>

        <!-- Card 4 -->
        <div class="group relative bg-white/70 dark:bg-gray-800/70 backdrop-blur-xl rounded-3xl p-6 border border-gray-200/50 dark:border-gray-700/50 hover:shadow-xl hover:shadow-green-500/10 dark:hover:shadow-green-500/20 transition-all duration-500 hover:-translate-y-1">
          <div class="w-14 h-14 bg-gradient-to-br from-green-500 to-green-600 rounded-2xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-green-500/30">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-2">
            Biaya Infrastruktur
          </h3>
          <p class="text-sm text-gray-500 dark:text-gray-500 mb-3">
            Infrastructure Costs
          </p>
          <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
            Server, database, dan bandwidth.
          </p>
        </div>
      </div>
    </div>
  </section>
  <!-- Support Options Section - FIXED: Active Links -->
  <section class="py-20 bg-white dark:bg-gray-900">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3">
          Cara Mendukung
        </h2>
        <h3 class="text-2xl md:text-3xl font-bold text-gray-600 dark:text-gray-400 mb-4">
          Ways to Support
        </h3>
        <p class="text-lg text-gray-500 dark:text-gray-500 max-w-2xl mx-auto">
          Pilih cara yang paling nyaman untuk Anda / Choose what works best for you
        </p>
      </div>

      <!-- Support Options Grid - FIXED: All buttons now active -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <!-- Ko-fi - ACTIVE LINK -->
        <a 
          href={KOFI_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative bg-gradient-to-br from-blue-50 to-blue-100 dark:from-gray-800 dark:to-blue-900/20 rounded-3xl p-8 border-2 border-blue-200 dark:border-blue-800 hover:shadow-2xl hover:shadow-blue-500/20 transition-all duration-300 hover:-translate-y-2 hover:scale-105"
        >
          <div class="flex flex-col items-center text-center">
            <div class="w-16 h-16 bg-blue-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 shadow-lg">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.216 6.415l-.132-.666c-.119-.598-.388-1.163-1.001-1.379-.197-.069-.42-.098-.57-.241-.152-.143-.196-.366-.231-.572-.065-.378-.125-.756-.192-1.133-.057-.325-.102-.69-.25-.987-.195-.4-.597-.634-.996-.788a5.723 5.723 0 00-.626-.194c-1-.263-2.05-.36-3.077-.416a25.834 25.834 0 00-3.7.062c-.915.083-1.88.184-2.75.5-.318.116-.646.256-.888.501-.297.302-.393.77-.177 1.146.154.267.415.456.692.58.36.162.737.284 1.123.366 1.075.238 2.189.331 3.287.37 1.218.05 2.437.01 3.65-.118.299-.033.598-.073.896-.119.352-.054.578-.513.474-.834-.124-.383-.457-.531-.834-.473-.466.074-.96.108-1.382.146-1.177.08-2.358.082-3.536.006a22.228 22.228 0 01-1.157-.107c-.086-.01-.18-.025-.258-.036-.243-.036-.484-.08-.724-.13-.111-.027-.111-.185 0-.212h.005c.277-.06.557-.108.838-.147h.002c.131-.009.263-.032.394-.048a25.076 25.076 0 013.426-.12c.674.019 1.347.067 2.017.144l.228.031c.267.04.533.088.798.145.392.085.895.113 1.07.542.055.137.08.288.111.431l.319 1.484a.237.237 0 01-.199.284h-.003c-.037.006-.075.01-.112.015a36.704 36.704 0 01-4.743.295 37.059 37.059 0 01-4.699-.304c-.14-.017-.293-.042-.417-.06-.326-.048-.649-.108-.973-.161-.393-.065-.768-.032-1.123.161-.29.16-.527.404-.675.701-.154.316-.199.66-.267 1-.069.34-.176.707-.135 1.056.087.753.613 1.365 1.37 1.502a39.69 39.69 0 0011.343.376.483.483 0 01.535.53l-.071.697-1.018 9.907c-.041.41-.047.832-.125 1.237-.122.637-.553 1.028-1.182 1.171-.577.131-1.165.2-1.756.205-.656.004-1.31-.025-1.966-.022-.699.004-1.556-.06-2.095-.58-.475-.458-.54-1.174-.605-1.793l-.731-7.013-.322-3.094c-.037-.351-.286-.695-.678-.678-.336.015-.718.3-.678.679l.228 2.185.949 9.112c.147 1.344 1.174 2.068 2.446 2.272.742.12 1.503.144 2.257.156.966.016 1.942.053 2.892-.122 1.408-.258 2.465-1.198 2.616-2.657.34-3.332.683-6.663 1.024-9.995l.215-2.087a.484.484 0 01.39-.426c.402-.078.787-.212 1.074-.518.455-.488.546-1.124.385-1.766zm-1.478.772c-.145.137-.363.201-.578.233-2.416.359-4.866.54-7.308.46-1.748-.06-3.477-.254-5.207-.498-.17-.024-.353-.055-.47-.18-.22-.236-.111-.71-.054-.995.052-.26.152-.609.463-.646.484-.057 1.046.148 1.526.22.577.088 1.156.159 1.737.212 2.48.226 5.002.19 7.472-.14.45-.06.899-.13 1.345-.21.399-.072.84-.206 1.08.206.166.281.188.657.162.974a.544.544 0 01-.169.364zm-6.159 3.9c-.862.37-1.84.788-3.109.788a5.884 5.884 0 01-1.569-.217l.877 9.004c.065.78.717 1.38 1.5 1.38 0 0 1.243.065 1.658.065.447 0 1.786-.065 1.786-.065.783 0 1.434-.6 1.499-1.38l.94-9.95a3.996 3.996 0 00-1.322-.238c-.826 0-1.491.284-2.26.613z"></path>
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 dark:text-gray-100 text-lg mb-2">Ko-fi</h4>
            <p class="text-sm text-gray-600 dark:text-gray-400">Buy me a coffee</p>
          </div>
        </a>

        <!-- Patreon - ACTIVE LINK -->
        <a 
          href={PATREON_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative bg-gradient-to-br from-orange-50 to-orange-100 dark:from-gray-800 dark:to-orange-900/20 rounded-3xl p-8 border-2 border-orange-200 dark:border-orange-800 hover:shadow-2xl hover:shadow-orange-500/20 transition-all duration-300 hover:-translate-y-2 hover:scale-105"
        >
          <div class="flex flex-col items-center text-center">
            <div class="w-16 h-16 bg-orange-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 shadow-lg">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M15.386.524c-4.764 0-8.64 3.876-8.64 8.64 0 4.75 3.876 8.613 8.64 8.613 4.75 0 8.614-3.864 8.614-8.613C24 4.4 20.136.524 15.386.524M.003 23.537h4.22V.524H.003"></path>
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 dark:text-gray-100 text-lg mb-2">Patreon</h4>
            <p class="text-sm text-gray-600 dark:text-gray-400">Monthly support</p>
          </div>
        </a>

        <!-- QRIS (Indonesia) - OPENS MODAL -->
        <button 
          id="show-qris-btn" 
          class="group relative bg-gradient-to-br from-purple-50 to-purple-100 dark:from-gray-800 dark:to-purple-900/20 rounded-3xl p-8 border-2 border-purple-200 dark:border-purple-800 hover:shadow-2xl hover:shadow-purple-500/20 transition-all duration-300 hover:-translate-y-2 hover:scale-105"
        >
          <div class="flex flex-col items-center text-center">
            <div class="w-16 h-16 bg-purple-500 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 shadow-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"></path>
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 dark:text-gray-100 text-lg mb-2">QRIS</h4>
            <p class="text-sm text-gray-600 dark:text-gray-400">Indonesia payment</p>
          </div>
        </button>
      </div>

      <!-- Soft Message - NO NOMINAL HERE -->
      <div class="bg-gradient-to-r from-purple-50 to-pink-50 dark:from-purple-900/10 dark:to-pink-900/10 rounded-3xl p-8 border border-purple-200/50 dark:border-purple-800/50 backdrop-blur-sm">
        <div class="flex items-start">
          <svg class="w-6 h-6 text-purple-600 dark:text-purple-400 mr-4 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
          </svg>
          <div class="flex-1">
            <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-3">
              <span class="font-semibold">🇮🇩 Indonesia:</span><br />
              Dukungan Anda bersifat sepenuhnya opsional. Jika Anda merasa platform ini bermanfaat, 
              Anda dapat mendukung pengembangannya secara sukarela. Platform ini akan tetap gratis digunakan.
            </p>
            <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
              <span class="font-semibold">🇬🇧 English:</span><br />
              Your support is completely optional. If you find this platform useful, 
              you may choose to support its development. The platform will always remain free to use.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- QRIS Modal - WITH NOMINAL SUGGESTIONS INSIDE -->
  <div id="qris-modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm transition-opacity"></div>
    
    <!-- Modal Content -->
    <div class="flex min-h-full items-center justify-center p-4">
      <div class="relative bg-white dark:bg-gray-900 rounded-3xl shadow-2xl max-w-2xl w-full p-8 transform transition-all">
        <!-- Close Button -->
        <button id="close-qris-btn" class="absolute top-4 right-4 p-2 rounded-full bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
          <svg class="w-6 h-6 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>

        <!-- Modal Header -->
        <div class="text-center mb-6">
          <h3 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-gray-100 mb-2">
            Scan QRIS
          </h3>
          <p class="text-gray-600 dark:text-gray-400">
            Gunakan aplikasi e-wallet atau mobile banking Anda
          </p>
          <p class="text-gray-600 dark:text-gray-400 text-sm">
            Use your e-wallet or mobile banking app
          </p>
        </div>

        <!-- Nominal Suggestions - MOVED HERE -->
        <div class="mb-6">
          <p class="text-sm text-gray-600 dark:text-gray-400 text-center mb-4">
            <span class="font-semibold">Pilih nominal sebagai referensi / Choose an amount as reference</span>
          </p>
          <div class="flex flex-wrap justify-center gap-3 mb-4">
            <button class="px-5 py-2.5 bg-white dark:bg-gray-800 border-2 border-gray-200 dark:border-gray-700 rounded-xl text-gray-700 dark:text-gray-300 font-medium hover:border-purple-500 dark:hover:border-purple-500 hover:text-purple-600 dark:hover:text-purple-400 hover:shadow-lg hover:scale-105 transition-all duration-300 text-sm">
              Rp 5.000
            </button>
            <button class="px-5 py-2.5 bg-white dark:bg-gray-800 border-2 border-gray-200 dark:border-gray-700 rounded-xl text-gray-700 dark:text-gray-300 font-medium hover:border-purple-500 dark:hover:border-purple-500 hover:text-purple-600 dark:hover:text-purple-400 hover:shadow-lg hover:scale-105 transition-all duration-300 text-sm">
              Rp 10.000
            </button>
            <button class="px-5 py-2.5 bg-white dark:bg-gray-800 border-2 border-gray-200 dark:border-gray-700 rounded-xl text-gray-700 dark:text-gray-300 font-medium hover:border-purple-500 dark:hover:border-purple-500 hover:text-purple-600 dark:hover:text-purple-400 hover:shadow-lg hover:scale-105 transition-all duration-300 text-sm">
              Rp 25.000
            </button>
            <button class="px-5 py-2.5 bg-gradient-to-r from-purple-500 to-pink-500 border-2 border-purple-500 rounded-xl text-white font-medium hover:from-purple-600 hover:to-pink-600 hover:shadow-lg hover:scale-105 transition-all duration-300 text-sm">
              Seikhlasnya / Any Amount
            </button>
          </div>
          
          <!-- Microcopy - ADDED -->

---
import Layout from '../../layouts/Layout.astro';
import AppCard from '../../components/AppCard.astro';
import { supabase } from '../../lib/supabase';

const { slug } = Astro.params;

// Initialize variables
let category = '';
let apps: any[] = [];
let count = 0;
let errorMessage = '';

// Get URL parameters
const url = Astro.url;
const sort = url.searchParams.get('sort') || 'latest';
const page = parseInt(url.searchParams.get('page') || '1');
const limit = 20;
const offset = (page - 1) * limit;

try {
  // First, get all unique categories
  const { data: allApps, error: fetchError } = await supabase
    .from('apps')
    .select('category')
    .eq('is_active', true);

  if (fetchError) {
    throw new Error(`Database error: ${fetchError.message}`);
  }

  // Get unique categories
  const categories = [...new Set(allApps?.map(app => app.category) || [])];
  
  // Find matching category (case-insensitive slug matching)
  for (const cat of categories) {
    const catSlug = cat.toLowerCase().replace(/\s+/g, '-');
    if (catSlug === slug) {
      category = cat;
      break;
    }
  }

  // If category not found, redirect to home
  if (!category) {
    return Astro.redirect('/');
  }

  // Build query for apps in this category
  let query = supabase
    .from('apps')
    .select('*', { count: 'exact' })
    .eq('is_active', true)
    .eq('category', category);

  // Apply sorting
  if (sort === 'popular') {
    query = query.not('stars', 'is', null).order('stars', { ascending: false });
  } else if (sort === 'name') {
    query = query.order('title', { ascending: true });
  } else {
    query = query.order('created_at', { ascending: false });
  }

  // Apply pagination
  query = query.range(offset, offset + limit - 1);

  // Execute query
  const { data: appsData, count: totalCount, error: queryError } = await query;

  if (queryError) {
    throw new Error(`Query error: ${queryError.message}`);
  }

  apps = appsData || [];
  count = totalCount || 0;

} catch (error) {
  console.error('[Category Page Error]:', error);
  errorMessage = error instanceof Error ? error.message : 'Unknown error occurred';
}

const totalPages = Math.ceil(count / limit);
const title = category ? `${category} - Free Downloads` : 'Category';
const description = category 
  ? `Download free ${category.toLowerCase()} from trusted sources. ${count} apps available.`
  : 'Browse apps by category';

// Category icons
const categoryIcons: Record<string, string> = {
  'Android Apps': 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z',
  'Windows Software': 'M0 0h11v11H0V0zm13 0h11v11H13V0zM0 13h11v11H0V13zm13 0h11v11H13V13z',
  'Developer Tools': 'M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z',
  'Productivity': 'M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z',
  'default': 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10'
};

const iconPath = categoryIcons[category] || categoryIcons['default'];
---

<Layout title={title} description={description}>
  <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
    
    {errorMessage ? (
      <!-- Error State -->
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="bg-red-50 dark:bg-red-900/20 border-2 border-red-200 dark:border-red-800 rounded-2xl p-8">
          <div class="flex items-start">
            <svg class="w-8 h-8 text-red-600 dark:text-red-400 mr-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div class="flex-1">
              <h3 class="text-xl font-bold text-red-900 dark:text-red-100 mb-2">
                Error Loading Category
              </h3>
              <p class="text-red-700 dark:text-red-300 mb-6">
                {errorMessage}
              </p>
              <div class="flex gap-3">
                <a 
                  href="/"
                  class="inline-flex items-center px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-xl transition-colors"
                >
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                  </svg>
                  Go Home
                </a>
                <button 
                  onclick="window.location.reload()"
                  class="inline-flex items-center px-6 py-3 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 font-semibold rounded-xl border-2 border-gray-300 dark:border-gray-600 transition-colors"
                >
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                  </svg>
                  Retry
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    ) : (
      <>
        <!-- Hero Section -->
        <section class="relative bg-gradient-to-br from-blue-50 via-white to-purple-50 dark:from-gray-900 dark:via-gray-900 dark:to-gray-800 py-16 md:py-20 border-b border-gray-200 dark:border-gray-700">
          <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
          
          <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Breadcrumb -->
            <nav class="flex mb-8" aria-label="Breadcrumb">
              <ol class="flex items-center space-x-2 text-sm">
                <li>
                  <a href="/" class="text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path>
                    </svg>
                  </a>
                </li>
                <li class="flex items-center">
                  <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="ml-2 text-gray-900 dark:text-gray-100 font-medium">{category}</span>
                </li>
              </ol>
            </nav>
            
            <div class="text-center max-w-4xl mx-auto">
              <!-- Icon -->
              <div class="flex items-center justify-center mb-6">
                <div class="w-20 h-20 bg-gradient-to-br from-blue-500 to-purple-600 rounded-3xl flex items-center justify-center shadow-xl">
                  <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d={iconPath}></path>
                  </svg>
                </div>
              </div>
              
              <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-gray-100 mb-4">
                {category}
              </h1>
              
              <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 mb-6">
                {count > 0 ? `${count} free apps and software` : 'Free apps and software'}
              </p>
              
              <div class="inline-flex items-center px-6 py-3 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl shadow-lg border border-gray-200/50 dark:border-gray-700/50">
                <svg class="w-5 h-5 text-blue-600 dark:text-blue-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                </svg>
                <span class="text-2xl font-bold text-gray-900 dark:text-gray-100 mr-2">{count}</span>
                <span class="text-gray-600 dark:text-gray-400">apps available</span>
              </div>
            </div>
          </div>
        </section>

        <!-- Apps Section -->
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
          {apps.length > 0 ? (
            <>
              <!-- Controls -->
              <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
                <p class="text-sm text-gray-600 dark:text-gray-400">
                  Showing {offset + 1}-{Math.min(offset + apps.length, count)} of {count} apps
                </p>
                
                <div class="flex items-center gap-3">
                  <label class="text-sm font-medium text-gray-700 dark:text-gray-300">
                    Sort by:
                  </label>
                  <select 
                    id="sort-select"
                    class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-xl bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                  >
                    <option value="latest" selected={sort === 'latest'}>Latest</option>
                    <option value="popular" selected={sort === 'popular'}>Most Popular</option>
                    <option value="name" selected={sort === 'name'}>Name A-Z</option>
                  </select>
                </div>
              </div>

              <!-- Apps Grid -->
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-12">
                {apps.map((app) => (
                  <AppCard app={app} />
                ))}
              </div>

              <!-- Pagination -->
              {totalPages > 1 && (
                <div class="flex items-center justify-center gap-2 flex-wrap">
                  {page > 1 && (
                    <a 
                      href={`/category/${slug}?sort=${sort}&page=${page - 1}`}
                      class="inline-flex items-center px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-700 transition-all shadow-sm"
                    >
                      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                      </svg>
                      Previous
                    </a>
                  )}
                  
                  {Array.from({ length: Math.min(5, totalPages) }, (_, i) => {
                    const pageNum = Math.max(1, Math.min(totalPages - 4, page - 2)) + i;
                    if (pageNum > totalPages) return null;
                    
                    return (
                      <a 
                        href={`/category/${slug}?sort=${sort}&page=${pageNum}`}
                        class={`inline-flex items-center justify-center w-10 h-10 text-sm font-medium rounded-xl transition-all ${
                          pageNum === page
                            ? 'bg-gradient-to-r from-blue-600 to-purple-600 text-white shadow-lg'
                            : 'text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 shadow-sm'
                        }`}
                      >
                        {pageNum}
                      </a>
                    );
                  })}
                  
                  {page < totalPages && (
                    <a 
                      href={`/category/${slug}?sort=${sort}&page=${page + 1}`}
                      class="inline-flex items-center px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-700 transition-all shadow-sm"
                    >
                      Next
                      <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                      </svg>
                    </a>
                  )}
                </div>
              )}
            </>
          ) : (
            <!-- Empty State -->
            <div class="bg-white dark:bg-gray-800 rounded-3xl p-16 text-center border-2 border-gray-200 dark:border-gray-700">
              <div class="w-24 h-24 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-3">
                No apps found in {category}
              </h3>
              <p class="text-gray-600 dark:text-gray-400 mb-8 max-w-md mx-auto">
                We're constantly adding new apps. Check back soon or browse other categories!
              </p>
              <a 
                href="/apps"
                class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white font-semibold rounded-2xl transition-all shadow-lg hover:shadow-xl"
              >
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                </svg>
                Browse All Apps
              </a>
            </div>
          )}
        </div>
      </>
    )}
  </div>
</Layout>

<style>
  .bg-grid-pattern {
    background-image: radial-gradient(circle, #e5e7eb 1px, transparent 1px);
    background-size: 20px 20px;
  }
</style>

<script>
  // Sort dropdown functionality
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
  
  if (sortSelect) {
    sortSelect.addEventListener('change', () => {
      const currentUrl = new URL(window.location.href);
      currentUrl.searchParams.set('sort', sortSelect.value);
      currentUrl.searchParams.delete('page'); // Reset to page 1 when sorting changes
      window.location.href = currentUrl.toString();
    });
  }
</script>

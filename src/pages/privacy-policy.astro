---
import Layout from '../layouts/Layout.astro';

// SEO Configuration
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://auto-download-center.vercel.app';
const pageTitle = "Privacy Policy - Auto Download Center | Data Protection & User Privacy";
const pageDescription = "Comprehensive privacy policy for Auto Download Center. Learn how we protect your data, handle cookies, and respect your privacy rights. GDPR compliant and transparent data practices.";
const lastUpdated = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Privacy Policy Structured Data
const privacyPolicyStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Privacy Policy",
  "description": pageDescription,
  "url": `${siteUrl}/privacy-policy`,
  "dateModified": new Date().toISOString(),
  "publisher": {
    "@type": "Organization",
    "name": "Auto Download Center",
    "url": siteUrl
  },
  "mainEntity": {
    "@type": "PrivacyPolicy",
    "name": "Auto Download Center Privacy Policy",
    "datePublished": "2026-01-01",
    "dateModified": new Date().toISOString(),
    "publisher": {
      "@type": "Organization", 
      "name": "Auto Download Center"
    }
  }
};
---

<Layout 
  title={pageTitle}
  description={pageDescription}
  canonical={`${siteUrl}/privacy-policy`}
>
  <!-- Privacy Policy Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(privacyPolicyStructuredData)} />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-blue-50 via-white to-purple-50 dark:from-gray-900 dark:via-gray-900 dark:to-gray-800 py-20 overflow-hidden">
    <!-- Animated Background -->
    <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob"></div>
    <div class="absolute top-0 right-1/4 w-96 h-96 bg-purple-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob animation-delay-2000"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <!-- Badge -->
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-sm font-medium mb-6 backdrop-blur-sm">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
          GDPR Compliant & Transparent
        </div>

        <!-- Main Heading -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-gray-100 mb-6 leading-tight">
          Privacy Policy
        </h1>
        
        <!-- Subtitle -->
        <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 mb-8 max-w-3xl mx-auto leading-relaxed">
          Your privacy matters to us. Learn how we protect your data and respect your rights.
        </p>

        <!-- Last Updated -->
        <div class="inline-flex items-center px-6 py-3 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl shadow-lg border border-gray-200/50 dark:border-gray-700/50">
          <svg class="w-5 h-5 text-gray-500 dark:text-gray-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Last updated: {lastUpdated}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Table of Contents -->
  <section class="py-12 bg-white dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-br from-blue-50 to-purple-50 dark:from-gray-800 dark:to-gray-700 rounded-3xl p-8 shadow-lg border border-gray-200 dark:border-gray-600">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center">
          <svg class="w-6 h-6 mr-3 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
          </svg>
          Table of Contents
        </h2>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="space-y-2">
            <a href="#overview" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-blue-600 dark:text-blue-400 font-medium group-hover:text-blue-700 dark:group-hover:text-blue-300">1. Overview & Commitment</span>
            </a>
            <a href="#information-collection" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-blue-600 dark:text-blue-400 font-medium group-hover:text-blue-700 dark:group-hover:text-blue-300">2. Information We Collect</span>
            </a>
            <a href="#data-usage" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-blue-600 dark:text-blue-400 font-medium group-hover:text-blue-700 dark:group-hover:text-blue-300">3. How We Use Your Data</span>
            </a>
            <a href="#cookies-tracking" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-blue-600 dark:text-blue-400 font-medium group-hover:text-blue-700 dark:group-hover:text-blue-300">4. Cookies & Tracking</span>
            </a>
            <a href="#third-party" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-blue-600 dark:text-blue-400 font-medium group-hover:text-blue-700 dark:group-hover:text-blue-300">5. Third-Party Services</span>
            </a>
          </div>
          <div class="space-y-2">
            <a href="#data-security" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-blue-600 dark:text-blue-400 font-medium group-hover:text-blue-700 dark:group-hover:text-blue-300">6. Data Security & Storage</span>
            </a>
            <a href="#user-rights" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-blue-600 dark:text-blue-400 font-medium group-hover:text-blue-700 dark:group-hover:text-blue-300">7. Your Rights (GDPR)</span>
            </a>
            <a href="#children-privacy" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-blue-600 dark:text-blue-400 font-medium group-hover:text-blue-700 dark:group-hover:text-blue-300">8. Children's Privacy</span>
            </a>
            <a href="#policy-updates" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-blue-600 dark:text-blue-400 font-medium group-hover:text-blue-700 dark:group-hover:text-blue-300">9. Policy Updates</span>
            </a>
            <a href="#contact" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-blue-600 dark:text-blue-400 font-medium group-hover:text-blue-700 dark:group-hover:text-blue-300">10. Contact Information</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-20 bg-gray-50 dark:bg-gray-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- 1. Overview & Commitment -->
      <div id="overview" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">1</span>
          </div>
          <div>
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">Overview & Our Commitment</h2>
            <div class="prose dark:prose-invert max-w-none">
              <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
                At Auto Download Center, we are committed to protecting your privacy and being transparent about how we handle your data. 
                This Privacy Policy explains what information we collect, how we use it, and your rights regarding your personal data.
              </p>
              
              <!-- Key Principles -->
              <div class="bg-gradient-to-r from-blue-50 to-purple-50 dark:from-gray-800 dark:to-gray-700 rounded-2xl p-6 mb-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-6 h-6 mr-2 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  Our Core Privacy Principles
                </h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-blue-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Minimal Data Collection:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> We only collect data necessary for our service</span>
                    </div>
                  </div>
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-purple-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Transparency:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> Clear communication about data practices</span>
                    </div>
                  </div>
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-pink-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">User Control:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> You have control over your data and privacy settings</span>
                    </div>
                  </div>
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-green-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Security First:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> Industry-standard security measures</span>
                    </div>
                  </div>
                </div>
              </div>

              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                This policy applies to all users of Auto Download Center and covers all data processing activities 
                related to our website and services. By using our platform, you agree to the practices described in this policy.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- 2. Information We Collect -->
      <div id="information-collection" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">2</span>
          </div>
          <div class="flex-1">
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6">Information We Collect</h2>
            
            <div class="space-y-8">
              <!-- Automatically Collected Information -->
              <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                  </svg>
                  Automatically Collected Information
                </h3>
                <div class="grid md:grid-cols-2 gap-6">
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">Technical Data</h4>
                    <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                      <li>• IP address (anonymized for analytics)</li>
                      <li>• Browser type and version</li>
                      <li>• Operating system</li>
                      <li>• Device type and screen resolution</li>
                      <li>• Referrer URL</li>
                      <li>• Pages visited and time spent</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">Usage Analytics</h4>
                    <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                      <li>• Download statistics (anonymous)</li>
                      <li>• Search queries (no personal data)</li>
                      <li>• Popular apps and categories</li>
                      <li>• User interaction patterns</li>
                      <li>• Performance metrics</li>
                      <li>• Error logs (anonymized)</li>
                    </ul>
                  </div>
                </div>
              </div>

              <!-- User Preferences -->
              <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                  User Preferences & Settings
                </h3>
                <p class="text-gray-600 dark:text-gray-400 mb-4">
                  We store minimal preference data locally in your browser to enhance your experience:
                </p>
                <ul class="space-y-2 text-gray-600 dark:text-gray-400">
                  <li class="flex items-start">
                    <div class="w-2 h-2 bg-purple-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div><strong>Theme Preference:</strong> Dark/light mode selection (stored locally)</div>
                  </li>
                  <li class="flex items-start">
                    <div class="w-2 h-2 bg-purple-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div><strong>Download History:</strong> Recent downloads (stored locally, max 50 entries)</div>
                  </li>
                  <li class="flex items-start">
                    <div class="w-2 h-2 bg-purple-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div><strong>Search History:</strong> Recent searches (stored locally, optional)</div>
                  </li>
                </ul>
              </div>

              <!-- Information We DON'T Collect -->
              <div class="bg-gradient-to-r from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6 border border-green-200 dark:border-green-700">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  What We DON'T Collect
                </h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <ul class="space-y-2 text-gray-600 dark:text-gray-400">
                    <li>✗ Personal identification information</li>
                    <li>✗ Email addresses (unless you contact us)</li>
                    <li>✗ Phone numbers or addresses</li>
                    <li>✗ Financial or payment information</li>
                  </ul>
                  <ul class="space-y-2 text-gray-600 dark:text-gray-400">
                    <li>✗ Social media profiles</li>
                    <li>✗ Biometric data</li>
                    <li>✗ Location tracking</li>
                    <li>✗ Cross-site tracking</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 3. How We Use Your Data -->
      <div id="data-usage" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-pink-500 to-pink-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">3</span>
          </div>
          <div class="flex-1">
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6">How We Use Your Data</h2>
            
            <div class="space-y-6">
              <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
                We use the collected information solely to provide and improve our services. Here's exactly how:
              </p>

              <div class="grid md:grid-cols-2 gap-6">
                <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                  <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-pink-600 dark:text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                    </svg>
                    Service Operations
                  </h3>
                  <ul class="space-y-2 text-gray-600 dark:text-gray-400">
                    <li>• Provide download links and app information</li>
                    <li>• Maintain website functionality</li>
                    <li>• Process search queries</li>
                    <li>• Generate app recommendations</li>
                    <li>• Monitor service performance</li>
                  </ul>
                </div>

                <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                  <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-pink-600 dark:text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                    Improvements & Analytics
                  </h3>
                  <ul class="space-y-2 text-gray-600 dark:text-gray-400">
                    <li>• Analyze usage patterns (anonymized)</li>
                    <li>• Improve user experience</li>
                    <li>• Optimize website performance</li>
                    <li>• Identify popular content</li>
                    <li>• Fix bugs and technical issues</li>
                  </ul>
                </div>

                <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                  <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-pink-600 dark:text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                    </svg>
                    Security & Safety
                  </h3>
                  <ul class="space-y-2 text-gray-600 dark:text-gray-400">
                    <li>• Prevent abuse and spam</li>
                    <li>• Detect suspicious activity</li>
                    <li>• Protect against malicious downloads</li>
                    <li>• Ensure service availability</li>
                    <li>• Comply with legal requirements</li>
                  </ul>
                </div>

                <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                  <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-pink-600 dark:text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                    </svg>
                    Communication
                  </h3>
                  <ul class="space-y-2 text-gray-600 dark:text-gray-400">
                    <li>• Respond to user inquiries</li>
                    <li>• Send important service updates</li>
                    <li>• Provide technical support</li>
                    <li>• Handle DMCA requests</li>
                    <li>• Process legal requests</li>
                  </ul>
                </div>
              </div>

              <!-- Legal Basis -->
              <div class="bg-gradient-to-r from-blue-50 to-purple-50 dark:from-gray-800 dark:to-gray-700 rounded-2xl p-6 border border-blue-200 dark:border-blue-700">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">

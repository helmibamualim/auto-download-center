---
import Layout from '../layouts/Layout.astro';

// SEO Configuration
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://auto-download-center.vercel.app';
const pageTitle = "Terms of Service - Auto Download Center | User Agreement & Legal Terms";
const pageDescription = "Comprehensive terms of service for Auto Download Center. Understand your rights, responsibilities, and legal agreements when using our free software download platform.";
const lastUpdated = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Terms of Service Structured Data
const termsStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Terms of Service",
  "description": pageDescription,
  "url": `${siteUrl}/terms`,
  "dateModified": new Date().toISOString(),
  "publisher": {
    "@type": "Organization",
    "name": "Auto Download Center",
    "url": siteUrl
  },
  "mainEntity": {
    "@type": "TermsOfService",
    "name": "Auto Download Center Terms of Service",
    "datePublished": "2026-01-01",
    "dateModified": new Date().toISOString(),
    "publisher": {
      "@type": "Organization", 
      "name": "Auto Download Center"
    }
  }
};
---

<Layout 
  title={pageTitle}
  description={pageDescription}
  canonical={`${siteUrl}/terms`}
>
  <!-- Terms of Service Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(termsStructuredData)} slot="head" />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-indigo-50 via-white to-blue-50 dark:from-gray-900 dark:via-gray-900 dark:to-gray-800 py-20 overflow-hidden">
    <!-- Animated Background -->
    <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-indigo-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob"></div>
    <div class="absolute top-0 right-1/4 w-96 h-96 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob animation-delay-2000"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <!-- Badge -->
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 text-sm font-medium mb-6 backdrop-blur-sm">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 2L3 7v11a1 1 0 001 1h3v-8h6v8h3a1 1 0 001-1V7l-7-5z" clip-rule="evenodd"></path>
          </svg>
          Legal Agreement & User Terms
        </div>

        <!-- Main Heading -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-gray-100 mb-6 leading-tight">
          Terms of Service
        </h1>
        
        <!-- Subtitle -->
        <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 mb-8 max-w-3xl mx-auto leading-relaxed">
          Your rights, responsibilities, and legal agreements when using our platform.
        </p>

        <!-- Last Updated -->
        <div class="inline-flex items-center px-6 py-3 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl shadow-lg border border-gray-200/50 dark:border-gray-700/50">
          <svg class="w-5 h-5 text-gray-500 dark:text-gray-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Last updated: {lastUpdated}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Table of Contents -->
  <section class="py-12 bg-white dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-br from-indigo-50 to-blue-50 dark:from-gray-800 dark:to-gray-700 rounded-3xl p-8 shadow-lg border border-gray-200 dark:border-gray-600">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center">
          <svg class="w-6 h-6 mr-3 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
          </svg>
          Table of Contents
        </h2>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="space-y-2">
            <a href="#acceptance" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">1. Acceptance of Terms</span>
            </a>
            <a href="#definitions" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">2. Definitions</span>
            </a>
            <a href="#service-description" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">3. Service Description</span>
            </a>
            <a href="#user-rights" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">4. User Rights & Responsibilities</span>
            </a>
            <a href="#prohibited-use" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">5. Prohibited Use</span>
            </a>
            <a href="#content-licensing" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">6. Content & Licensing</span>
            </a>
          </div>
          <div class="space-y-2">
            <a href="#third-party" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">7. Third-Party Links & Services</span>
            </a>
            <a href="#disclaimers" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">8. Disclaimers & Warranties</span>
            </a>
            <a href="#liability" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">9. Limitation of Liability</span>
            </a>
            <a href="#termination" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">10. Termination & Violations</span>
            </a>
            <a href="#updates" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">11. Terms Updates</span>
            </a>
            <a href="#contact" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">12. Contact & Legal</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-20 bg-gray-50 dark:bg-gray-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- 1. Acceptance of Terms -->
      <div id="acceptance" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-indigo-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">1</span>
          </div>
          <div>
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">Acceptance of Terms</h2>
            <div class="prose dark:prose-invert max-w-none">
              <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
                By accessing, browsing, or using Auto Download Center (the "Service"), you acknowledge that you have read, 
                understood, and agree to be bound by these Terms of Service and all applicable laws and regulations.
              </p>
              
              <!-- Agreement Conditions -->
              <div class="bg-gradient-to-r from-indigo-50 to-blue-50 dark:from-gray-800 dark:to-gray-700 rounded-2xl p-6 mb-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-6 h-6 mr-2 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  By Using Our Service, You Agree To:
                </h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-indigo-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Legal Compliance:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> Follow all applicable laws and regulations</span>
                    </div>
                  </div>
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-blue-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Terms Binding:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> Accept these terms as legally binding</span>
                    </div>
                  </div>
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-purple-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Age Requirement:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> Be at least 13 years old or have parental consent</span>
                    </div>
                  </div>
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-pink-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Updates Acceptance:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> Accept future updates to these terms</span>
                    </div>
                  </div>
                </div>
              </div>

              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                If you do not agree to these terms, please do not use our Service. Your continued use of the Service 
                constitutes acceptance of any modifications to these terms.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- 2. Definitions -->
      <div id="definitions" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">2</span>
          </div>
          <div class="flex-1">
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6">Definitions</h2>
            
            <div class="space-y-6">
              <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
                For the purposes of these Terms of Service, the following definitions apply:
              </p>

              <div class="grid gap-6">
                <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                  <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H3m2 0h4M9 7h6m-6 4h6m-6 4h6"></path>
                    </svg>
                    Key Terms & Definitions
                  </h3>
                  <div class="space-y-4">
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">"Service" or "Platform":</strong>
                      <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">
                        Refers to Auto Download Center website, including all pages, features, and functionality
                      </p>
                    </div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">"User" or "You":</strong>
                      <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">
                        Any individual or entity that accesses or uses our Service
                      </p>
                    </div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">"Content":</strong>
                      <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">
                        All software listings, descriptions, links, and information provided on our platform
                      </p>
                    </div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">"Third-Party Software":</strong>
                      <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">
                        Software applications developed and owned by external developers and publishers
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 3. Service Description -->
      <div id="service-description" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">3</span>
          </div>
          <div class="flex-1">
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6">Service Description</h2>
            
            <div class="space-y-6">
              <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
                Auto Download Center is a software discovery and indexing platform that provides users with access to 
                free, legal, and open-source software applications.
              </p>

              <!-- What We Provide -->
              <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  What We Provide
                </h3>
                <div class="grid md:grid-cols-2 gap-6">
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">Software Discovery</h4>
                    <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                      <li>• Curated software listings</li>
                      <li>• Detailed app descriptions</li>
                      <li>• Category-based organization</li>
                      <li>• Search and filtering tools</li>
                      <li>• User ratings and reviews</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">Download Links</h4>
                    <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                      <li>• Direct links to official sources</li>
                      <li>• Multiple download options</li>
                      <li>• Version information</li>
                      <li>• Platform compatibility</li>
                      <li>• Safety verification</li>
                    </ul>
                  </div>
                </div>
              </div>

              <!-- What We Don't Do -->
              <div class="bg-gradient-to-r from-red-50 to-orange-50 dark:from-red-900/20 dark:to-orange-900/20 rounded-2xl p-6 border border-red-200 dark:border-red-700">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                  </svg>
                  Important: What We Don't Do
                </h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <ul class="space-y-2 text-gray-600 dark:text-gray-400">
                    <li>✗ Host software files directly</li>
                    <li>✗ Modify or alter software</li>
                    <li>✗ Provide technical support for software</li>
                    <li>✗ Guarantee software functionality</li>
                  </ul>
                  <ul class="space-y-2 text-gray-600 dark:text-gray-400">
                    <li>✗ Index illegal or pirated software</li>
                    <li>✗ Distribute copyrighted content</li>
                    <li>✗ Provide software licenses</li>
                    <li>✗ Warranty software performance</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- 11. Terms Updates -->
      <div id="updates" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-cyan-500 to-cyan-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">11</span>
          </div>
          <div class="flex-1">
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6">Terms Updates</h2>
            
            <div class="space-y-6">
              <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
                How we handle updates to these Terms of Service and notify users of changes.
              </p>

              <!-- Update Process -->
              <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-cyan-600 dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                  </svg>
                  Update Process & Timeline
                </h3>
                <div class="space-y-4">
                  <p class="text-gray-600 dark:text-gray-400">
                    We may update these Terms of Service from time to time to reflect changes in our practices, 
                    legal requirements, or service improvements.
                  </p>
                  <div class="grid md:grid-cols-3 gap-4">
                    <div class="text-center p-4 bg-cyan-50 dark:bg-cyan-900/20 rounded-xl border border-cyan-200 dark:border-cyan-700">
                      <div class="w-8 h-8 bg-cyan-500 rounded-full flex items-center justify-center mx-auto mb-2">
                        <span class="text-white font-bold text-sm">1</span>
                      </div>
                      <h4 class="font-semibold text-gray-900 dark:text-gray-100 text-sm mb-1">Review</h4>
                      <p class="text-gray-600 dark:text-gray-400 text-xs">Internal review and legal validation</p>
                    </div>
                    <div class="text-center p-4 bg-cyan-50 dark:bg-cyan-900/20 rounded-xl border border-cyan-200 dark:border-cyan-700">
                      <div class="w-8 h-8 bg-cyan-500 rounded-full flex items-center justify-center mx-auto mb-2">
                        <span class="text-white font-bold text-sm">2</span>
                      </div>
                      <h4 class="font-semibold text-gray-900 dark:text-gray-100 text-sm mb-1">Publish</h4>
                      <p class="text-gray-600 dark:text-gray-400 text-xs">Update website with new terms</p>
                    </div>
                    <div class="text-center p-4 bg-cyan-50 dark:bg-cyan-900/20 rounded-xl border border-cyan-200 dark:border-cyan-700">
                      <div class="w-8 h-8 bg-cyan-500 rounded-full flex items-center justify-center mx-auto mb-2">
                        <span class="text-white font-bold text-sm">3</span>
                      </div>
                      <h4 class="font-semibold text-gray-900 dark:text-gray-100 text-sm mb-1">Notify</h4>
                      <p class="text-gray-600 dark:text-gray-400 text-xs">Inform users of significant changes</p>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Notification Methods -->
              <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-5 5v-5zM4 19h6v-2H4v2zM4 15h8v-2H4v2zM4 11h10V9H4v2z"></path>
                  </svg>
                  How We Notify You
                </h3>
                <div class="grid md:grid-cols-2 gap-6">
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">For All Changes</h4>
                    <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                      <li>• Updated "Last updated" date on this page</li>
                      <li>• Version history maintained</li>
                      <li>• Changes highlighted in document</li>
                      <li>• Summary of modifications provided</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">For Material Changes</h4>
                    <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                      <li>• Prominent notice on homepage</li>
                      <li>• Banner notification on website</li>
                      <li>• Email notification (if contact provided)</li>
                      <li>• 30-day advance notice when possible</li>
                    </ul>

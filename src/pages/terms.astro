---
import Layout from '../layouts/Layout.astro';

// SEO Configuration
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://auto-download-center.vercel.app';
const pageTitle = "Terms of Service - Auto Download Center | Simple User Agreement";
const pageDescription = "Simple and easy-to-understand terms of service for Auto Download Center. We provide information and services following applicable regulations.";
const lastUpdated = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Terms of Service Structured Data
const termsStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Terms of Service",
  "description": pageDescription,
  "url": `${siteUrl}/terms`,
  "dateModified": new Date().toISOString(),
  "publisher": {
    "@type": "Organization",
    "name": "Auto Download Center",
    "url": siteUrl
  },
  "mainEntity": {
    "@type": "TermsOfService",
    "name": "Auto Download Center Terms of Service",
    "datePublished": "2026-01-01",
    "dateModified": new Date().toISOString(),
    "publisher": {
      "@type": "Organization", 
      "name": "Auto Download Center"
    }
  }
};
---

<Layout 
  title={pageTitle}
  description={pageDescription}
  canonical={`${siteUrl}/terms`}
>
  <!-- Terms of Service Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(termsStructuredData)} slot="head" />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-indigo-50 via-white to-blue-50 dark:from-gray-900 dark:via-gray-900 dark:to-gray-800 py-20 overflow-hidden">
    <!-- Animated Background -->
    <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-indigo-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob"></div>
    <div class="absolute top-0 right-1/4 w-96 h-96 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob animation-delay-2000"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <!-- Badge -->
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 text-sm font-medium mb-6 backdrop-blur-sm">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 2L3 7v11a1 1 0 001 1h3v-8h6v8h3a1 1 0 001-1V7l-7-5z" clip-rule="evenodd"></path>
          </svg>
          Simple User Agreement
        </div>

        <!-- Main Heading -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-gray-100 mb-6 leading-tight">
          Terms of Service
        </h1>
        
        <!-- Subtitle -->
        <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 mb-8 max-w-3xl mx-auto leading-relaxed">
          Simple and flexible terms for using our platform. We keep it straightforward and user-friendly.
        </p>

        <!-- Last Updated -->
        <div class="inline-flex items-center px-6 py-3 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl shadow-lg border border-gray-200/50 dark:border-gray-700/50">
          <svg class="w-5 h-5 text-gray-500 dark:text-gray-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Last updated: {lastUpdated}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Table of Contents -->
  <section class="py-12 bg-white dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-br from-indigo-50 to-blue-50 dark:from-gray-800 dark:to-gray-700 rounded-3xl p-8 shadow-lg border border-gray-200 dark:border-gray-600">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center">
          <svg class="w-6 h-6 mr-3 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
          </svg>
          Table of Contents
        </h2>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="space-y-2">
            <a href="#acceptance" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">1. Agreement Acceptance</span>
            </a>
            <a href="#service-description" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">2. About Our Service</span>
            </a>
            <a href="#user-guidelines" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">3. User Guidelines</span>
            </a>
            <a href="#content-policy" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">4. Content Policy</span>
            </a>
          </div>
          <div class="space-y-2">
            <a href="#third-party" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">5. Third-Party Links</span>
            </a>
            <a href="#disclaimers" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">6. Service Disclaimers</span>
            </a>
            <a href="#updates" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">7. Terms Updates</span>
            </a>
            <a href="#contact" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-indigo-600 dark:text-indigo-400 font-medium group-hover:text-indigo-700 dark:group-hover:text-indigo-300">8. Contact Information</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-20 bg-gray-50 dark:bg-gray-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- 1. Agreement Acceptance -->
      <div id="acceptance" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-indigo-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">1</span>
          </div>
          <div>
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">Agreement Acceptance</h2>
            <div class="prose dark:prose-invert max-w-none">
              <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
                By using Auto Download Center, you agree to these simple and flexible terms. 
                We're committed to providing a helpful and easy-to-use service for everyone.
              </p>
              
              <!-- Agreement Conditions -->
              <div class="bg-gradient-to-r from-indigo-50 to-blue-50 dark:from-gray-800 dark:to-gray-700 rounded-2xl p-6 mb-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-6 h-6 mr-2 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  By Using Our Service, You Agree To:
                </h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-indigo-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Fair Use:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> Use our service responsibly and respectfully</span>
                    </div>
                  </div>
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-blue-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Simple Terms:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> Accept these straightforward and flexible terms</span>
                    </div>
                  </div>
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-purple-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Age Requirement:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> Recommended for users 13 years and older</span>
                    </div>
                  </div>
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-pink-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Updates:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> We'll notify you of any important changes</span>
                    </div>
                  </div>
                </div>
              </div>

              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                If you don't agree with these terms, please stop using our service. 
                Continued use indicates your acceptance of these terms.
              </p>
            </div>
          </div>
        </div>
      </div>
      <!-- 2. About Our Service -->
      <div id="service-description" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">2</span>
          </div>
          <div class="flex-1">
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6">About Our Service</h2>
            
            <div class="space-y-6">
              <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
                Auto Download Center is an information platform that helps you find free and legal software. 
                We serve as information providers following applicable rules and regulations.
              </p>

              <!-- What We Provide -->
              <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  What We Provide
                </h3>
                <div class="grid md:grid-cols-2 gap-6">
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">Software Information</h4>
                    <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                      <li>• Curated software listings</li>
                      <li>• Detailed descriptions and information</li>
                      <li>• Organized categories</li>
                      <li>• Search and filter features</li>
                      <li>• User ratings and reviews</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">Download Links</h4>
                    <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                      <li>• Links to official sources</li>
                      <li>• Multiple download options</li>
                      <li>• Latest version information</li>
                      <li>• Platform compatibility details</li>
                      <li>• Basic security verification</li>
                    </ul>
                  </div>
                </div>
              </div>

              <!-- Important Notes -->
              <div class="bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6 border border-blue-200 dark:border-blue-700">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  Important Notes
                </h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <ul class="space-y-2 text-gray-600 dark:text-gray-400">
                    <li>• We don't host software files directly</li>
                    <li>• We don't modify or alter software</li>
                    <li>• We don't provide technical support for software</li>
                    <li>• We only provide information and links</li>
                  </ul>
                  <ul class="space-y-2 text-gray-600 dark:text-gray-400">
                    <li>• We don't distribute illegal software</li>
                    <li>• We follow applicable copyright laws</li>
                    <li>• We strive to provide accurate information</li>
                    <li>• We respect software developers' rights</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 3. User Guidelines -->
      <div id="user-guidelines" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-green-500 to-green-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">3</span>
          </div>
          <div class="flex-1">
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6">User Guidelines</h2>
            
            <div class="space-y-6">
              <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
                Simple guidelines to ensure a positive experience for everyone using our platform.
              </p>

              <!-- Acceptable Use -->
              <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  Encouraged Use
                </h3>
                <div class="grid md:grid-cols-2 gap-6">
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">Platform Usage</h4>
                    <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                      <li>• Browse and search for software</li>
                      <li>• Read software descriptions and reviews</li>
                      <li>• Use download links responsibly</li>
                      <li>• Share helpful feedback and reviews</li>
                      <li>• Report broken links or issues</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">Community Behavior</h4>
                    <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                      <li>• Be respectful to other users</li>
                      <li>• Provide constructive feedback</li>
                      <li>• Help improve the platform</li>
                      <li>• Follow software licensing terms</li>
                      <li>• Use software legally and ethically</li>
                    </ul>
                  </div>
                </div>
              </div>

              <!-- Usage Recommendations -->
              <div class="bg-gradient-to-r from-yellow-50 to-orange-50 dark:from-yellow-900/20 dark:to-orange-900/20 rounded-2xl p-6 border border-yellow-200 dark:border-yellow-700">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-yellow-600 dark:text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                  </svg>
                  Best Practices
                </h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <ul class="space-y-2 text-gray-600 dark:text-gray-400">
                    <li>• Always verify software authenticity before downloading</li>
                    <li>• Read software licenses and terms before use</li>
                    <li>• Keep your antivirus software updated</li>
                    <li>• Backup important data before installing new software</li>
                  </ul>
                  <ul class="space-y-2 text-gray-600 dark:text-gray-400">
                    <li>• Check system requirements before downloading</li>
                    <li>• Download only from trusted sources</li>
                    <li>• Report suspicious or malicious software</li>
                    <li>• Respect intellectual property rights</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- 4. Content Policy -->
      <div id="content-policy" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-orange-500 to-orange-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">4</span>
          </div>
          <div class="flex-1">
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6">Content Policy</h2>
            
            <div class="space-y-6">
              <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
                Understanding content ownership and licensing helps ensure proper and legal use of our platform.
              </p>

              <!-- Our Content -->
              <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                  Platform Content
                </h3>
                <div class="grid md:grid-cols-2 gap-6">
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">Our Intellectual Property</h4>
                    <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                      <li>• Website design and layout</li>
                      <li>• Auto Download Center branding</li>
                      <li>• Original descriptions and content</li>
                      <li>• Database organization</li>
                      <li>• Custom features and functionality</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">Usage Rights</h4>
                    <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                      <li>• Personal, non-commercial use</li>
                      <li>• No redistribution without permission</li>
                      <li>• No modification of our content</li>
                      <li>• Attribution required when sharing</li>
                      <li>• Rights may be revoked if misused</li>
                    </ul>
                  </div>
                </div>
              </div>

              <!-- Third-Party Software -->
              <div class="bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6 border border-blue-200 dark:border-blue-700">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                  </svg>
                  Third-Party Software Licensing
                </h3>
                <div class="space-y-4">
                  <p class="text-gray-600 dark:text-gray-400">
                    All software listed on our platform is owned by their respective developers. 
                    Each software has its own license terms that users must follow.
                  </p>
                  <div class="grid md:grid-cols-3 gap-4">
                    <div class="text-center p-4 bg-green-50 dark:bg-green-900/20 rounded-xl border border-green-200 dark:border-green-700">
                      <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center mx-auto mb-2">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                      </div>
                      <h4 class="font-semibold text-gray-900 dark:text-gray-100 text-sm">Open Source</h4>
                      <p class="text-gray-600 dark:text-gray-400 text-xs mt-1">Free to use, modify, distribute</p>
                    </div>
                    <div class="text-center p-4 bg-blue-50 dark:bg-blue-900/20 rounded-xl border border-blue-200 dark:border-blue-700">
                      <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center mx-auto mb-2">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                        </svg>
                      </div>
                      <h4 class="font-semibold text-gray-900 dark:text-gray-100 text-sm">Freeware</h4>

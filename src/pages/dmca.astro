---
import Layout from '../layouts/Layout.astro';

// SEO Configuration
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://auto-download-center.vercel.app';
const pageTitle = "DMCA Policy - Auto Download Center | Copyright Protection";
const pageDescription = "Simple and clear DMCA policy for Auto Download Center. We respect copyright and provide easy procedures for reporting concerns.";
const lastUpdated = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// DMCA Policy Structured Data
const dmcaStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "DMCA Policy",
  "description": pageDescription,
  "url": `${siteUrl}/dmca`,
  "dateModified": new Date().toISOString(),
  "publisher": {
    "@type": "Organization",
    "name": "Auto Download Center",
    "url": siteUrl
  }
};
---

<Layout 
  title={pageTitle}
  description={pageDescription}
  canonical={`${siteUrl}/dmca`}
>
  <!-- DMCA Policy Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(dmcaStructuredData)} slot="head" />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-green-50 via-white to-blue-50 dark:from-gray-900 dark:via-gray-900 dark:to-gray-800 py-20 overflow-hidden">
    <!-- Animated Background -->
    <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-green-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob"></div>
    <div class="absolute top-0 right-1/4 w-96 h-96 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-blob animation-delay-2000"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <!-- Badge -->
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 text-sm font-medium mb-6 backdrop-blur-sm">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
          Copyright Protection
        </div>

        <!-- Main Heading -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-gray-100 mb-6 leading-tight">
          DMCA Policy
        </h1>
        
        <!-- Subtitle -->
        <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 mb-8 max-w-3xl mx-auto leading-relaxed">
          We respect copyright and make it easy to report concerns. Simple process, quick response.
        </p>

        <!-- Last Updated -->
        <div class="inline-flex items-center px-6 py-3 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl shadow-lg border border-gray-200/50 dark:border-gray-700/50">
          <svg class="w-5 h-5 text-gray-500 dark:text-gray-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Last updated: {lastUpdated}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Table of Contents -->
  <section class="py-12 bg-white dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-br from-green-50 to-blue-50 dark:from-gray-800 dark:to-gray-700 rounded-3xl p-8 shadow-lg border border-gray-200 dark:border-gray-600">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center">
          <svg class="w-6 h-6 mr-3 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
          </svg>
          Table of Contents
        </h2>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="space-y-2">
            <a href="#overview" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-green-600 dark:text-green-400 font-medium group-hover:text-green-700 dark:group-hover:text-green-300">1. Our Commitment</span>
            </a>
            <a href="#what-we-index" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-green-600 dark:text-green-400 font-medium group-hover:text-green-700 dark:group-hover:text-green-300">2. What We Index</span>
            </a>
            <a href="#reporting-process" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-green-600 dark:text-green-400 font-medium group-hover:text-green-700 dark:group-hover:text-green-300">3. Reporting Process</span>
            </a>
            <a href="#how-to-report" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-green-600 dark:text-green-400 font-medium group-hover:text-green-700 dark:group-hover:text-green-300">4. How to Report</span>
            </a>
          </div>
          <div class="space-y-2">
            <a href="#our-response" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-green-600 dark:text-green-400 font-medium group-hover:text-green-700 dark:group-hover:text-green-300">5. Our Response</span>
            </a>
            <a href="#counter-notification" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-green-600 dark:text-green-400 font-medium group-hover:text-green-700 dark:group-hover:text-green-300">6. Counter-Notification</span>
            </a>
            <a href="#important-notes" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-green-600 dark:text-green-400 font-medium group-hover:text-green-700 dark:group-hover:text-green-300">7. Important Notes</span>
            </a>
            <a href="#contact" class="block p-3 rounded-xl hover:bg-white/50 dark:hover:bg-gray-600/50 transition-colors group">
              <span class="text-green-600 dark:text-green-400 font-medium group-hover:text-green-700 dark:group-hover:text-green-300">8. Contact Information</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-20 bg-gray-50 dark:bg-gray-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- 1. Our Commitment -->
      <div id="overview" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-green-500 to-green-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">1</span>
          </div>
          <div>
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">Our Commitment</h2>
            <div class="prose dark:prose-invert max-w-none">
              <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
                Auto Download Center respects intellectual property rights and takes copyright seriously. 
                We only provide information about free and legal software from official sources.
              </p>
              
              <!-- Key Principles -->
              <div class="bg-gradient-to-r from-green-50 to-blue-50 dark:from-gray-800 dark:to-gray-700 rounded-2xl p-6 mb-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-6 h-6 mr-2 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  Our Copyright Principles
                </h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-green-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Respect Rights:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> We respect all intellectual property rights</span>
                    </div>
                  </div>
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-blue-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Legal Content Only:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> Only free and legal software information</span>
                    </div>
                  </div>
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-purple-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Quick Response:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> Fast response to valid copyright concerns</span>
                    </div>
                  </div>
                  <div class="flex items-start">
                    <div class="w-2 h-2 bg-pink-500 rounded-full mt-2 mr-3 flex-shrink-0"></div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Easy Process:</strong>
                      <span class="text-gray-600 dark:text-gray-400"> Simple reporting process for copyright holders</span>
                    </div>
                  </div>
                </div>
              </div>

              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                We serve as an information platform, providing links to official sources and free software. 
                If you have copyright concerns, we're here to help resolve them quickly and fairly.
              </p>
            </div>
          </div>
        </div>
      </div>
      <!-- 2. What We Index -->
      <div id="what-we-index" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">2</span>
          </div>
          <div class="flex-1">
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6">What We Index</h2>
            
            <div class="space-y-6">
              <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
                We only provide information about software that is free, legal, and properly licensed for distribution.
              </p>

              <!-- What We Include -->
              <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  Software We Include
                </h3>
                <div class="grid md:grid-cols-2 gap-6">
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">Free & Open Source</h4>
                    <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                      <li>• Open source software (OSS)</li>
                      <li>• GNU GPL licensed software</li>
                      <li>• MIT and Apache licensed software</li>
                      <li>• Creative Commons licensed software</li>
                      <li>• Public domain software</li>
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">Officially Free Software</h4>
                    <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                      <li>• Freeware from official developers</li>
                      <li>• Software with explicit free distribution</li>
                      <li>• Trial versions from official sources</li>
                      <li>• Educational software (free versions)</li>
                      <li>• Community editions</li>
                    </ul>
                  </div>
                </div>
              </div>

              <!-- What We Don't Include -->
              <div class="bg-gradient-to-r from-red-50 to-orange-50 dark:from-red-900/20 dark:to-orange-900/20 rounded-2xl p-6 border border-red-200 dark:border-red-700">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                  </svg>
                  Software We DON'T Include
                </h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <ul class="space-y-2 text-gray-600 dark:text-gray-400">
                    <li>✗ Copyrighted commercial software</li>
                    <li>✗ Cracked or pirated software</li>
                    <li>✗ Modified or patched software</li>
                    <li>✗ Software without proper licensing</li>
                  </ul>
                  <ul class="space-y-2 text-gray-600 dark:text-gray-400">
                    <li>✗ Unauthorized redistributions</li>
                    <li>✗ Software with unclear licensing</li>
                    <li>✗ Any copyright-infringing content</li>
                    <li>✗ Malware or suspicious software</li>
                  </ul>
                </div>
              </div>

              <!-- Our Role -->
              <div class="bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-2xl p-6 border border-blue-200 dark:border-blue-700">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  Important: Our Role
                </h3>
                <p class="text-gray-600 dark:text-gray-400">
                  We are an information platform that provides links to official sources. We don't host files directly 
                  but help users find legitimate software from authorized distributors and developers.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 3. Reporting Process -->
      <div id="reporting-process" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">3</span>
          </div>
          <div class="flex-1">
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6">Reporting Process</h2>
            
            <div class="space-y-6">
              <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
                If you believe content on our site infringes your copyright, here's what you need to include in your report:
              </p>

              <!-- Required Information -->
              <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                  Required Information
                </h3>
                <div class="space-y-4">
                  <div class="grid md:grid-cols-2 gap-6">
                    <div>
                      <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">Basic Information</h4>
                      <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                        <li>• Your name and signature</li>
                        <li>• Your contact information</li>
                        <li>• Your relationship to the copyright</li>
                        <li>• Description of your copyrighted work</li>
                      </ul>
                    </div>
                    <div>
                      <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">Specific Details</h4>
                      <ul class="space-y-1 text-gray-600 dark:text-gray-400 text-sm">
                        <li>• URL of the infringing content</li>
                        <li>• Description of the infringement</li>
                        <li>• Good faith statement</li>
                        <li>• Accuracy statement under penalty of perjury</li>
                      </ul>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Simple Template -->
              <div class="bg-gradient-to-r from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl p-6 border border-green-200 dark:border-green-700">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                  Simple Report Template
                </h3>
                <div class="bg-white dark:bg-gray-800 rounded-xl p-4 font-mono text-sm">
                  <p class="text-gray-600 dark:text-gray-400">
                    Subject: DMCA Copyright Notice<br><br>
                    
                    I am the copyright owner of: [Your copyrighted work]<br>
                    The infringing content is located at: [URL on our site]<br>
                    My contact information: [Your email and address]<br><br>
                    
                    I have a good faith belief that the use is not authorized.<br>
                    This information is accurate and I am authorized to act on behalf of the copyright owner.<br><br>
                    
                    Signature: [Your name]<br>
                    Date: [Today's date]
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 4. How to Report -->
      <div id="how-to-report" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-orange-500 to-orange-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">4</span>
          </div>
          <div class="flex-1">
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6">How to Report</h2>
            
            <div class="space-y-6">
              <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
                Send your copyright notice to our designated agent. We make it simple and straightforward.
              </p>

              <!-- Contact Information -->
              <div class="bg-gradient-to-br from-orange-50 to-red-50 dark:from-orange-900/20 dark:to-red-900/20 rounded-2xl p-6 border border-orange-200 dark:border-orange-700">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                  DMCA Contact Information
                </h3>
                <div class="bg-white dark:bg-gray-800 rounded-xl p-6">
                  <div class="space-y-3">
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">DMCA Agent</strong><br>
                      <span class="text-gray-600 dark:text-gray-400">Auto Download Center</span>
                    </div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Email:</strong>
                      <a href="mailto:dmca@autodownloadcenter.com" class="text-orange-600 dark:text-orange-400 hover:text-orange-700 dark:hover:text-orange-300 font-medium ml-2">
                        dmca@autodownloadcenter.com
                      </a>
                    </div>
                    <div>
                      <strong class="text-gray-900 dark:text-gray-100">Subject Line:</strong>
                      <span class="text-gray-600 dark:text-gray-400 ml-2">DMCA Copyright Notice</span>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Alternative Contact -->
              <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-6">
                <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-4">Alternative Contact Methods</h3>
                <div class="grid md:grid-cols-2 gap-4">
                  <div>
                    <strong class="text-gray-900 dark:text-gray-100">General Contact:</strong>
                    <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">
                      Use our <a href="/contact" class="text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300">contact form</a> for urgent matters
                    </p>
                  </div>
                  <div>
                    <strong class="text-gray-900 dark:text-gray-100">Response Time:</strong>
                    <p class="text-gray-600 dark:text-gray-400 text-sm mt-1">
                      We respond to valid DMCA notices within 24-48 hours
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- 5. Our Response -->
      <div id="our-response" class="bg-white dark:bg-gray-900 rounded-3xl p-8 mb-12 shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="flex items-start mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-teal-500 to-teal-600 rounded-2xl flex items-center justify-center mr-4 flex-shrink-0">
            <span class="text-white font-bold text-lg">5</span>
          </div>
          <div class="flex-1">
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6">Our Response</h2>
            
            <div class="space-y-6">
              <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
                When we receive a valid copyright notice, we take prompt action to address the concern.
              </p>

              <!-- Response Process -->
